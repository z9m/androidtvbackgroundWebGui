as Honigsenf, das in den Laden zur\u00fcckgegeben wurde, versucht die anderen Produkte vor dem wirklichen, grausamen Schicksal zu warnen, das bei den Menschen auf sie wartet, aber weder Frank und Brenda noch deren leckeren Kollegen wie Sammy Bagel Jr. oder Vash wollen dem Horrorszenario Glauben schenken \u2013 bis sie schon bald in der K\u00fcche einer Eink\u00e4uferin am eigenen Leib erfahren, dass die gefr\u00e4\u00dfigen Riesen selbst vor kleinen Karottenkindern keinen Halt machen\u2026", "selectable": true, "evented": true, "lockScalingY": false, "fixedHeight": 300, "editable": false}, {"type": "image", "version": "5.3.0", "originX": "left", "originY": "top", "left": 1409.36, "top": 25, "width": 1278, "height": 445, "fill": "rgb(0,0,0)", "stroke": null, "strokeWidth": 0, "strokeDashArray": null, "strokeLineCap": "butt", "strokeDashOffset": 0, "strokeLineJoin": "miter", "strokeUniform": false, "strokeMiterLimit": 4, "scaleX": 0.38, "scaleY": 0.38, "angle": 0, "flipX": false, "flipY": false, "opacity": 1, "shadow": null, "visible": true, "backgroundColor": "", "fillRule": "nonzero", "paintFirst": "fill", "globalCompositeOperation": "source-over", "skewX": 0, "skewY": 0, "cropX": 0, "cropY": 0, "dataTag": "title", "selectable": true, "evented": true, "lockScalingY": false, "src": "http://localhost:5000/api/proxy/image?url=http%3A%2F%2Ftruenas%3A30013%2FItems%2Fa6ca7f99ce89df29ca1c579aa694e246%2FImages%2FLogo%3Fapi_key%3Db00ae14a7c3249b2b154f22f75e1ecfd", "crossOrigin": "anonymous", "filters": []}, {"type": "image", "version": "5.3.0", "originX": "left", "originY": "top", "left": 1590.295, "top": 204.1, "width": 768, "height": 768, "fill": "rgb(0,0,0)", "stroke": null, "strokeWidth": 0, "strokeDashArray": null, "strokeLineCap": "butt", "strokeDashOffset": 0, "strokeLineJoin": "miter", "strokeUniform": false, "strokeMiterLimit": 4, "scaleX": 0.035, "scaleY": 0.035, "angle": 0, "flipX": false, "flipY": false, "opacity": 1, "shadow": null, "visible": true, "backgroundC